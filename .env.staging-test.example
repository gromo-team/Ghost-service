# Local test of the production image against the STAGING MySQL.
# Copy to .env.staging-test, fill in real values, then run:
#
#   docker run --rm --env-file .env.staging-test -p 2368:2368 \
#     -v ghost-staging-content:/home/ghost/content ghost-service:local
#
# Then open http://localhost:2368/ghost
#
# NOTE: Ghost runs migrations on boot and creates ~100+ tables in this database.
# Use a database dedicated to Ghost (zyra_ghost_service) — never one shared with
# other apps' tables.

NODE_ENV=production

# Public URL. For a local test against staging DB, localhost is fine. In AKS this
# becomes your real domain (https://...).
url=http://localhost:2368

server__host=0.0.0.0
server__port=2368

database__client=mysql
database__connection__host=<staging-mysql-host>       # e.g. zyra-staging-db.mysql.database.azure.com
database__connection__port=3306
database__connection__user=<staging-mysql-user>
database__connection__password=<staging-mysql-password>
database__connection__database=zyra_ghost_service

# Azure Database for MySQL requires TLS. Uncomment if your staging server enforces it:
# database__connection__ssl__rejectUnauthorized=true
